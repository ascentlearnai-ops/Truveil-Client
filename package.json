{
  "name": "truveil-secure",
  "version": "1.0.0",
  "description": "Truveil Secure Interview Client",
  "main": "main.js",
  "author": "Truveil Inc.",
  "scripts": {
    "test": "node --test test/*.test.js",
    "check": "node --check main.js && node --check preload.js && node --check src/renderer/session.js",
    "prestart": "node scripts/write-runtime-config.js",
    "start": "electron .",
    "prebuild:mac": "node scripts/write-runtime-config.js --production",
    "build:mac": "electron-builder --mac",
    "prebuild:win": "node scripts/write-runtime-config.js --production",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "dotenv": "^16.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.9.1"
  }
}
